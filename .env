# ===========================================
# Insurance Broker Workbench - Environment Configuration
# ===========================================

# ---------------------------------------------
# Azure AI Foundry (Agents)
# ---------------------------------------------
# Azure AI Foundry project endpoint (required for agents)
AZURE_AI_FOUNDRY_ENDPOINT=https://brockerworkbench-ai.cognitiveservices.azure.com/

# Azure AI Foundry project connection string (set automatically in Azure; not required for local dev)
# Format: <endpoint>/api/projects/<projectName>
AZURE_AI_FOUNDRY_PROJECT_CONNECTION_STRING=

# Model deployment name in Azure AI Foundry
AZURE_AI_MODEL_DEPLOYMENT=gpt-4.1

# ---------------------------------------------
# Azure Resources
# ---------------------------------------------
# Resource group for all Azure resources
AZURE_RESOURCE_GROUP=rg-hackathon

# Azure region
AZURE_LOCATION=eastus

# Azure subscription ID
AZURE_SUBSCRIPTION_ID=784cb9b8-0f32-4cfe-ba5c-8bb75735b217

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
# For SQLite (development) - leave empty to use local SQLite files
# DATABASE_URL=

# For Azure SQL (production) - uses Azure AD authentication
# Format: mssql+pyodbc://server:port/database?driver=ODBC+Driver+18+for+SQL+Server&Authentication=ActiveDirectoryDefault
AZURE_SQL_CONNECTION_STRING=mssql+pyodbc://sql-brokerworkbench-dev.database.windows.net:1433/sqldb-brokerworkbench-dev?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no&Authentication=ActiveDirectoryDefault

# Set to "true" to see SQL queries in console (debugging)
SQL_ECHO=false

# ---------------------------------------------
# Application Settings
# ---------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
