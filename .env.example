# ===========================================
# Insurance Broker Workbench - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
#
# AUTHENTICATION: This project uses Azure Entra ID (formerly AAD) ONLY.
# No API keys are used.  Two local auth paths are supported:
#
#   Path A — Azure CLI cache mount (recommended for local dev):
#     1. On your HOST machine: az login
#     2. docker-compose up  (the ~/.azure dir is bind-mounted read-only into the container)
#     3. AZURE_CONFIG_DIR in docker-compose.yml points the CLI credential to the mount.
#
#   Path B — Service Principal env vars (for CI or shared dev boxes):
#     1. Create a SP:  az ad sp create-for-rbac --name broker-local-dev
#     2. Assign role: az role assignment create --role "Cognitive Services OpenAI User" \
#          --assignee <SP_CLIENT_ID> --scope /subscriptions/<SUB>/resourceGroups/<RG>/providers/...
#     3. Set AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_CLIENT_SECRET below and restart.
#
# Check auth status at any time:  GET http://localhost:8000/api/agent/health

# ---------------------------------------------
# Azure AI Foundry / Azure OpenAI (Agents)
# ---------------------------------------------
# Azure OpenAI / AI Foundry endpoint (required for agents)
# Format: https://<resource-name>.cognitiveservices.azure.com/
#    or   https://<project>.<region>.api.azureml.ms  (AI Foundry project endpoint)
AZURE_AI_FOUNDRY_ENDPOINT=

# Model deployment name (must exist in Azure AI Foundry / Azure OpenAI Studio)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4.1

# Optional API version override (defaults to 2024-12-01-preview)
# AZURE_AI_API_VERSION=2024-12-01-preview

# ---------------------------------------------
# Entra Auth - Service Principal (Path B)
# ---------------------------------------------
# Leave blank to use Azure CLI cache (Path A).
# All three must be set together to activate SP auth.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
# Alternative: certificate instead of secret:
# AZURE_CLIENT_CERTIFICATE_PATH=

# ---------------------------------------------
# Azure Resources
# ---------------------------------------------
# Resource group for all Azure resources
AZURE_RESOURCE_GROUP=

# Azure region
AZURE_LOCATION=eastus

# Azure subscription ID
AZURE_SUBSCRIPTION_ID=

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
# For SQLite (development) - leave empty to use local SQLite files
# DATABASE_URL=

# For Azure SQL (production) - uses Azure AD (Entra) authentication; no password needed
# Format: mssql+pyodbc://server:port/database?driver=ODBC+Driver+18+for+SQL+Server&Authentication=ActiveDirectoryDefault
AZURE_SQL_CONNECTION_STRING=

# Set to "true" to see SQL queries in console (debugging)
SQL_ECHO=false

# ---------------------------------------------
# Application Settings
# ---------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated) — set in Azure Container App environment
# Leave empty for permissive development mode (allow all)
# Example: https://ca-frontend-brokerworkbench-dev.azurecontainerapps.io
CORS_ALLOWED_ORIGINS=
