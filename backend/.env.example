# ===========================================
# Insurance Broker Workbench - Environment Configuration
# ===========================================
# NOTE: The actual .env file lives at the PROJECT ROOT (../), not here.
# This file is kept for reference only.
# Copy the root .env.example to ../.env and configure there.

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
# For SQLite (development) - leave empty or comment out
# DATABASE_URL=

# For Azure SQL (production) - uses Entra auth (no password)
# DATABASE_URL=mssql+pyodbc://server.database.windows.net:1433/dbname?driver=ODBC+Driver+18+for+SQL+Server&Authentication=ActiveDirectoryDefault

# Master database (reference data) - optional, defaults to data/db/master_data.db
# MASTER_DATABASE_URL=

# Set to "true" to see SQL queries in console (debugging)
SQL_ECHO=false

# ---------------------------------------------
# Azure OpenAI / AI Foundry (Agents) — Entra auth only, no API keys
# ---------------------------------------------
# Required: endpoint for your Azure OpenAI or AI Foundry resource
# Format: https://<resource>.cognitiveservices.azure.com/
AZURE_AI_FOUNDRY_ENDPOINT=

# Model deployment name (must exist in the resource above)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4.1

# Optional: API version (defaults to 2024-12-01-preview)
# AZURE_AI_API_VERSION=2024-12-01-preview

# Optional: Model parameters
# AZURE_AI_MAX_TOKENS=4096
# AZURE_AI_TEMPERATURE=0.7

# ---------------------------------------------
# Entra Auth — Service Principal (optional, Path B)
# ---------------------------------------------
# Leave blank to use Azure CLI credential (Path A, requires host az login + volume mount).
# To use SP: set all three and the SP must have "Cognitive Services OpenAI User" role.
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# ---------------------------------------------
# Application Settings
# ---------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
