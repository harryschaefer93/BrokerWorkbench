    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('backendAppName')]",
      "location": "[parameters('location')]",
      "tags": "[union(variables('tags'), createObject('component', 'backend'))]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-backend-{0}', variables('resourceSuffix'))))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvName'))]",
        "configuration": {
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-11-01-preview').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-backend-{0}', variables('resourceSuffix')))]"
            }
          ],
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http",
            "allowInsecure": false,
            "corsPolicy": {
              "allowedOrigins": "[union(createArray(format('https://{0}.{1}', variables('frontendAppName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvName')), '2024-03-01').defaultDomain)), if(equals(parameters('environment'), 'dev'), createArray('http://localhost:3000', 'http://127.0.0.1:5500'), createArray()))]",
              "allowedMethods": [
                "GET",
                "POST",
                "PUT",
                "DELETE",
                "OPTIONS"
              ],
              "allowedHeaders": [
                "*"
              ],
              "allowCredentials": true
            }
          },
          "secrets": [
            {
              "name": "sql-connection-string",
              "keyVaultUrl": "[reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'sql-connection-string'), '2023-07-01').secretUri]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-backend-{0}', variables('resourceSuffix')))]"
            },
            {
              "name": "appinsights-connection-string",
              "keyVaultUrl": "[reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'appinsights-connection-string'), '2023-07-01').secretUri]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-backend-{0}', variables('resourceSuffix')))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "backend",
              "image": "[parameters('backendContainerImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "DATABASE_URL",
                  "secretRef": "sql-connection-string"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secretRef": "appinsights-connection-string"
                },
                {
                  "name": "ENVIRONMENT",
                  "value": "[parameters('environment')]"
                },
                {
                  "name": "AZURE_CLIENT_ID",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-backend-{0}', variables('resourceSuffix'))), '2023-01-31').clientId]"
                },
                {
                  "name": "AZURE_AI_FOUNDRY_PROJECT_CONNECTION_STRING",
                  "value": "[format('{0}/api/projects/{1}', reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiFoundryName')), '2025-04-01-preview').endpoint, parameters('aiProjectName'))]"
                },
                {
                  "name": "AZURE_AI_FOUNDRY_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiFoundryName')), '2025-04-01-preview').endpoint]"
                },
                {
                  "name": "AZURE_AI_MODEL_DEPLOYMENT",
                  "value": "[parameters('aiModelDeploymentName')]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[variables('containerScaleMap')[parameters('environment')].minReplicas]",
            "maxReplicas": "[variables('containerScaleMap')[parameters('environment')].maxReplicas]",
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[extensionResourceId(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-backend-{0}', variables('resourceSuffix'))), 'acrpull'))]",
