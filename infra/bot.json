            }
          ],
          "ingress": {
            "external": true,
            "targetPort": 3978,
            "transport": "auto",
            "allowInsecure": false
          },
          "secrets": [
            {
              "name": "microsoft-app-password",
              "value": "[parameters('microsoftAppPassword')]"
            }
