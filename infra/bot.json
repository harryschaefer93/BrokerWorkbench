                },
                {
                  "name": "MICROSOFT_APP_PASSWORD",
                  "secretRef": "microsoft-app-password"
                },
                {
                  "name": "BACKEND_URL",
                  "value": "[format('https://{0}', parameters('backendFqdn'))]"
                },
                {
                  "name": "BOT_PORT",
                  "value": "3978"
