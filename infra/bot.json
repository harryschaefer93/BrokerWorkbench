        },
        "template": {
          "containers": [
            {
              "name": "broker-bot",
              "image": "[format('{0}/{1}', reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer, parameters('botContainerImage'))]",
